{
  "name": "@amulet-laboratories/hex",
  "version": "0.2.0",
  "type": "module",
  "description": "Multi-theme layer for Rig — curated palettes targeting data-rig-* selectors",
  "license": "MIT",
  "author": "Amulet Laboratories",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "keywords": [
    "css",
    "themes",
    "design-tokens",
    "tailwindcss",
    "vue",
    "design-system"
  ],
  "homepage": "https://github.com/Amulet-Laboratories/rig/tree/main/hex#readme",
  "bugs": {
    "url": "https://github.com/Amulet-Laboratories/rig/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/rig",
    "directory": "hex"
  },
  "exports": {
    ".": "./dist/hex.css",
    "./source": "./src/index.css",
    "./vscode": "./dist/vscode.css",
    "./vscode/source": "./src/themes/vscode/index.css",
    "./garden": "./dist/garden.css",
    "./garden/source": "./src/themes/garden/index.css",
    "./spacewizard": "./dist/spacewizard.css",
    "./spacewizard/source": "./src/themes/spacewizard/index.css",
    "./greyline": "./dist/greyline.css",
    "./greyline/source": "./src/themes/greyline/index.css",
    "./tidemark": "./dist/tidemark.css",
    "./tidemark/source": "./src/themes/tidemark/index.css",
    "./briarcove": "./dist/briarcove.css",
    "./briarcove/source": "./src/themes/briarcove/index.css",
    "./duskline": "./dist/duskline.css",
    "./duskline/source": "./src/themes/duskline/index.css",
    "./saltsignal": "./dist/saltsignal.css",
    "./saltsignal/source": "./src/themes/saltsignal/index.css",
    "./marenlys": "./dist/marenlys.css",
    "./marenlys/source": "./src/themes/marenlys/index.css",
    "./lanternhouse": "./dist/lanternhouse.css",
    "./lanternhouse/source": "./src/themes/lanternhouse/index.css",
    "./aldricpace": "./dist/aldricpace.css",
    "./aldricpace/source": "./src/themes/aldricpace/index.css",
    "./undertow": "./dist/undertow.css",
    "./undertow/source": "./src/themes/undertow/index.css",
    "./kbcv": "./dist/kbcv.css",
    "./kbcv/source": "./src/themes/kbcv/index.css",
    "./compass": "./dist/compass.css",
    "./compass/source": "./src/themes/compass/index.css",
    "./briarcovelib": "./dist/briarcovelib.css",
    "./briarcovelib/source": "./src/themes/briarcovelib/index.css",
    "./scoped": "./dist/scoped.css",
    "./scoped/source": "./src/scoped/index.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "node --test build.test.mjs",
    "lint": "eslint .",
    "lint:css": "stylelint 'src/**/*.css'",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@amulet-laboratories/config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "cssnano": "^7.1.3",
    "eslint": "^9.20.0",
    "postcss": "^8.5.0",
    "postcss-import": "^16.1.0",
    "prettier": "^3.5.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.1"
  }
}
