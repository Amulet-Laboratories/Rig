{
  "name": "@amulet-laboratories/rig",
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "description": "Headless, accessible Vue 3 component library — VSCode-style, slot-driven, unstyled",
  "license": "MIT",
  "author": "Amulet Laboratories",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/rig"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/base.css",
    "./scaffold": "./src/styles/scaffold.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "headless",
    "accessible",
    "a11y",
    "design-system",
    "typescript"
  ],
  "homepage": "https://github.com/Amulet-Laboratories/rig#readme",
  "bugs": {
    "url": "https://github.com/Amulet-Laboratories/rig/issues"
  },
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "vitest",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit",
    "check": "concurrently -n lint,fmt,tsc -c magenta,cyan,yellow \"eslint .\" \"prettier --write .\" \"vue-tsc --noEmit\"",
    "build": "vite build",
    "prepublishOnly": "pnpm build",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "story:dev": "histoire dev",
    "story:build": "histoire build && node scripts/histoire-post-build.mjs",
    "story:preview": "histoire preview"
  },
  "lint-staged": {
    "*.{ts,vue}": "eslint --fix",
    "*.{ts,vue,css,json,md}": "prettier --write"
  },
  "peerDependencies": {
    "@floating-ui/vue": "^1.0.0",
    "@iconify/vue": "^4.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@iconify/vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@amulet-laboratories/config": "workspace:*",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@floating-ui/vue": "^1.1.11",
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@iconify/vue": "^4.3.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.20.0",
    "histoire": "1.0.0-beta.1",
    "husky": "^9.0.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
