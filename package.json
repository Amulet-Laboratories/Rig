{
  "name": "@amulet-laboratories/rig",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "description": "Headless, accessible Vue 3 component library — VSCode-style, slot-driven, unstyled",
  "license": "MIT",
  "author": "Amulet Laboratories",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/rig"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/base.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@floating-ui/vue": "^1.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@floating-ui/vue": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@iconify/vue": "^4.0.0"
  },
  "devDependencies": {
    "@amulet-laboratories/config": "file:../Config",
    "@amulet-laboratories/hex": "file:../Hex",
    "@floating-ui/vue": "^1.1.11",
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@iconify/vue": "^4.3.0",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.20.0",
    "histoire": "1.0.0-beta.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
