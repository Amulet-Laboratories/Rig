{
  "name": "@amulet-laboratories/rig",
  "version": "0.1.0",
  "type": "module",
  "description": "Headless, accessible Vue 3 component library — VSCode-style, slot-driven, unstyled",
  "license": "MIT",
  "author": "Amulet Laboratories",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/rig"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "@floating-ui/vue": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@floating-ui/vue": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@iconify/vue": "^4.0.0"
  },
  "devDependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@iconify/vue": "^4.3.0",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.20.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
