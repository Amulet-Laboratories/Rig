{
  "name": "@amulet-laboratories/rig",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "description": "Headless, accessible Vue 3 component library — VSCode-style, slot-driven, unstyled",
  "license": "MIT",
  "author": "Amulet Laboratories",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/rig"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/base.css",
    "./scaffold": "./src/styles/scaffold.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": false,
  "keywords": ["vue", "vue3", "components", "headless", "accessible", "a11y", "design-system", "typescript"],
  "homepage": "https://github.com/Amulet-Laboratories/rig#readme",
  "bugs": {
    "url": "https://github.com/Amulet-Laboratories/rig/issues"
  },
  "scripts": {
    "dev": "node scripts/dev-watcher.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit",
    "check": "concurrently -n lint,fmt,tsc -c magenta,cyan,yellow \"eslint .\" \"prettier --write .\" \"vue-tsc --noEmit\"",
    "build": "vite build",
    "comparison": "vitest run -c vitest.comparison.ts",
    "cross-comparison": "vitest run -c vitest.cross-comparison.ts",
    "health": "pnpm check && pnpm build && vitest run --reporter=json --outputFile=.health/tests.json --coverage && vitest bench --run --outputJson=.health/bench.json && pnpm cross-comparison && node scripts/tree-shake-analysis.mjs && node scripts/generate-health-manifest.mjs && tsx scripts/collect-intelligence.ts && pnpm audit",
    "tree-shake": "node scripts/tree-shake-analysis.mjs",
    "health:diff": "node scripts/health-diff.mjs"
  },
  "peerDependencies": {
    "@floating-ui/vue": "^1.0.0",
    "@iconify/vue": "^4.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@floating-ui/vue": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@amulet-laboratories/config": "workspace:*",
    "@floating-ui/vue": "^1.1.11",
    "@headlessui/vue": "^1.7.23",
    "@iconify/vue": "^4.3.0",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.0",
    "ant-design-vue": "^4.2.6",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.20.0",
    "flowbite-vue": "^0.2.3",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "reka-ui": "^2.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
