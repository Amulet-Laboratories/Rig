{
  "name": "@amulet-laboratories/rig",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "description": "Headless, accessible Vue 3 component library — VSCode-style, slot-driven, unstyled",
  "license": "MIT",
  "author": "Amulet Laboratories",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/rig"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/base.css",
    "./scaffold": "./src/styles/scaffold.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles",
    "packages"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "bench:collect": "vitest bench --run --outputJson=.health/bench.json",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "demo:dev": "cd demo && pnpm dev",
    "lab:dev": "cd lab && pnpm dev",
    "hex:dev": "cd ../Hex && pnpm dev",
    "dev": "concurrently -n lab,watch -c cyan,yellow \"pnpm lab:dev\" \"node scripts/dev-watcher.mjs\"",
    "dev:all": "concurrently -n lab,watch,hex,story,demo -c cyan,yellow,green,magenta,blue \"pnpm lab:dev\" \"node scripts/dev-watcher.mjs\" \"pnpm hex:dev\" \"pnpm story:dev\" \"pnpm demo:dev\"",
    "health:collect": "vitest run --reporter=json --outputFile=.health/tests.json --coverage",
    "health:generate": "node scripts/generate-health-manifest.mjs",
    "health": "pnpm health:collect && pnpm bench:collect && pnpm health:generate",
    "compare:bench": "vitest run --config lab/bench/vitest.config.ts",
    "compare:static": "node scripts/analyze-competitors.mjs",
    "compare": "pnpm compare:bench && pnpm compare:static",
    "collect": "node scripts/collect-all.mjs",
    "collect:quick": "node scripts/collect-all.mjs --quick",
    "collect:full": "node scripts/collect-all.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@floating-ui/vue": "^1.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@floating-ui/vue": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@iconify/vue": "^4.0.0"
  },
  "devDependencies": {
    "@amulet-laboratories/config": "file:../Config",
    "@amulet-laboratories/hex": "file:../Hex",
    "@chakra-ui/react": "^3.34.0",
    "@floating-ui/vue": "^1.1.11",
    "@headlessui/vue": "^1.7.23",
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@iconify/vue": "^4.3.0",
    "@mantine/core": "^8.3.16",
    "@mui/material": "^7.3.9",
    "@types/node": "^22.13.0",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.0",
    "ant-design-vue": "^4.2.6",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.20.0",
    "flowbite-vue": "^0.2.3",
    "histoire": "1.0.0-beta.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "radix-vue": "^1.9.17",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
